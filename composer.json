{
    "name": "410-gone/qcdredis",
    "description": "Replace the PrestaShop cache engine with Redis using only native PrestaShop mechanisms. No overrides, fully reversible.",
    "type": "prestashop-module",
    "license": "proprietary",
    "authors": [
        {
            "name": "410 Gone",
            "homepage": "https://410-gone.fr"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-redis": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "prestashop/php-dev-tools": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "QcdGone\\QcdRedis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QcdGone\\QcdRedis\\Tests\\": "tests/"
        }
    },
    "config": {
        "prepend-autoloader": false,
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=-1",
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix"
    }
}
