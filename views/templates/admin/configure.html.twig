{# QCD Redis - Back office interface (Twig). #}
{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<link rel="stylesheet" href="{{ assetsUrl }}css/qcdredis.css">
<div class="qcd-redis" id="qcd-redis-app"
     data-url-test="{{ path('qcdredis_admin_test_connection') }}"
     data-url-stats="{{ path('qcdredis_admin_stats') }}"
     data-url-diagnostics="{{ path('qcdredis_admin_diagnostics') }}"
     data-url-benchmark="{{ path('qcdredis_admin_benchmark') }}"
     data-url-export="{{ path('qcdredis_admin_export_csv') }}"
     data-url-purge="{{ path('qcdredis_admin_purge') }}"
     data-url-warmup-build="{{ path('qcdredis_admin_warmup_build') }}"
     data-url-warmup-batch="{{ path('qcdredis_admin_warmup_batch') }}">

    {# ---------------- Hero / statut ---------------- #}
    <div class="qcd-hero">
        <div class="qcd-hero-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"></path><path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"></path>
            </svg>
        </div>
        <div class="qcd-hero-text">
            <h2 class="qcd-hero-title">QCD Redis <small>par 410 Gone</small></h2>
            <p class="qcd-hero-sub">Accélère votre boutique en stockant le cache dans Redis. Réservé au front-office : l'administration n'est jamais mise en cache.</p>
        </div>
        {% if overview.available %}
            <span class="qcd-status qcd-status-ok"><span class="dot"></span> Redis en ligne &middot; v{{ overview.version }}</span>
        {% else %}
            <span class="qcd-status qcd-status-off"><span class="dot"></span> Redis injoignable</span>
        {% endif %}
    </div>

    {# ---------------- Onglets ---------------- #}
    <ul class="qcd-nav nav nav-tabs" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-qcd-tab="dashboard" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"></path><path d="M18 20V4"></path><path d="M6 20v-4"></path></svg>
            <span>Tableau de bord</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="connection" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v6"></path><path d="M15 2v6"></path><path d="M6 8h12v3a6 6 0 0 1-12 0Z"></path><path d="M12 17v5"></path></svg>
            <span>Connexion</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="cache" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line><circle cx="9" cy="6" r="2" fill="#fff"></circle><circle cx="15" cy="12" r="2" fill="#fff"></circle><circle cx="8" cy="18" r="2" fill="#fff"></circle></svg>
            <span>Réglages du cache</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="purge" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M8 6V4h8v2"></path><path d="M19 6l-1 14H6L5 6"></path></svg>
            <span>Vider le cache</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="warmup" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s5 4 5 9a5 5 0 0 1-10 0c0-2 1-3 1-3s0 2 2 2c0-3 2-5 2-8Z"></path></svg>
            <span>Préchauffage</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="statistics" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><path d="M7 14l4-4 3 3 5-6"></path></svg>
            <span>Statistiques</span></a></li>
        <li class="nav-item"><a class="nav-link" data-qcd-tab="diagnostic" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5Z"></path><path d="m9 12 2 2 4-4"></path></svg>
            <span>Diagnostic</span></a></li>
    </ul>

    <div class="qcd-panels">

        {# ---------------- Tableau de bord ---------------- #}
        <section class="qcd-panel active" data-qcd-panel="dashboard">
            <div class="qcd-panel-head">
                <h3>Tableau de bord</h3>
                <p>Un coup d'œil sur l'état de votre serveur Redis.</p>
            </div>

            {% if overview.available %}
                <div class="qcd-callout qcd-callout-ok">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
                    <span>Tout va bien : votre serveur Redis répond. Les chiffres ci-dessous sont mis à jour en temps réel.</span>
                </div>
            {% else %}
                <div class="qcd-callout qcd-callout-warn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    <span>Redis est <strong>injoignable</strong> depuis l'administration. Vérifiez l'adresse et le port dans l'onglet <strong>Connexion</strong>, puis cliquez sur <strong>Tester la connexion</strong>.</span>
                </div>
            {% endif %}

            <div class="qcd-grid" id="qcd-dashboard-grid">
                {% if overview.available %}
                    {% set cards = {
                        'version': 'Version', 'latency_ms': 'Latence (ms)',
                        'used_memory_human': 'Mémoire utilisée', 'free_memory': 'Mémoire libre (octets)',
                        'keys': 'Clés en cache', 'connected_clients': 'Clients connectés',
                        'hit_ratio': 'Taux de succès (%)', 'miss_ratio': "Taux d'échec (%)",
                        'uptime_seconds': 'Disponibilité (s)', 'fragmentation_ratio': 'Fragmentation',
                        'evicted_keys': 'Évictions', 'expired_keys': 'Expirations'
                    } %}
                    {% for key, label in cards %}
                        <div class="qcd-card"><span class="qcd-metric" data-metric="{{ key }}">{{ overview[key] }}</span><span class="qcd-label">{{ label }}</span></div>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="qcd-actions">
                <button type="button" class="btn btn-outline-secondary qcd-action" data-qcd-refresh="dashboard">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path><path d="M3 21v-5h5"></path></svg>
                    Actualiser
                </button>
            </div>
        </section>

        {# ---------------- Connexion ---------------- #}
        <section class="qcd-panel" data-qcd-panel="connection">
            <div class="qcd-panel-head">
                <h3>Connexion à Redis</h3>
                <p>Indiquez où se trouve votre serveur Redis.</p>
            </div>

            <div class="qcd-callout qcd-callout-info">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                <span>En cas de doute, gardez les valeurs par défaut (<strong>127.0.0.1</strong>, port <strong>6379</strong>) et cliquez sur <strong>Tester la connexion</strong>. Enregistrez seulement si le test est vert.</span>
            </div>

            {{ form_start(connectionForm) }}
                <div class="qcd-section">
                    <div class="qcd-section-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"></rect><rect x="2" y="14" width="20" height="8" rx="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
                        Serveur
                    </div>
                    {{ form_row(connectionForm.host) }}
                    {{ form_row(connectionForm.port) }}
                    {{ form_row(connectionForm.password) }}
                    {{ form_row(connectionForm.db) }}
                    {{ form_row(connectionForm.timeout) }}
                    {{ form_row(connectionForm.tls) }}
                </div>
                <div class="qcd-actions">
                    <button type="button" class="btn btn-outline-secondary" id="qcd-test-connection">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
                        Tester la connexion
                    </button>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
                <p class="qcd-result" id="qcd-connection-result"></p>
            {{ form_end(connectionForm) }}
        </section>

        {# ---------------- Réglages du cache ---------------- #}
        <section class="qcd-panel" data-qcd-panel="cache">
            <div class="qcd-panel-head">
                <h3>Réglages du cache</h3>
                <p>Choisissez où et comment Redis met votre boutique en cache.</p>
            </div>

            {{ form_start(cacheForm) }}
                <div class="qcd-section">
                    <div class="qcd-section-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10"></path><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path></svg>
                        Activation
                    </div>
                    <p class="qcd-hint">Interrupteur principal du module. S'il est désactivé, Redis n'est pas utilisé du tout.</p>
                    {{ form_row(cacheForm.enabled) }}
                </div>

                <div class="qcd-section">
                    <div class="qcd-section-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18"></path></svg>
                        Où activer le cache
                    </div>
                    <p class="qcd-hint">Recommandé : laisser <strong>Front</strong> et <strong>Front (AJAX)</strong> activés. Redis est dédié au front-office ; l'administration, la CLI et le cron ne sont jamais mis en cache.</p>
                    {{ form_row(cacheForm.front) }}
                    {{ form_row(cacheForm.front_ajax) }}
                </div>

                <div class="qcd-section">
                    <div class="qcd-section-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"></path></svg>
                        Options avancées
                    </div>
                    <p class="qcd-hint">Réservé aux utilisateurs avertis. Les valeurs par défaut conviennent à la plupart des boutiques.</p>
                    {{ form_row(cacheForm.ttl) }}
                    {{ form_row(cacheForm.prefix) }}
                    {{ form_row(cacheForm.compression) }}
                    {{ form_row(cacheForm.compression_auto) }}
                    {{ form_row(cacheForm.compression_threshold) }}
                    {{ form_row(cacheForm.serializer) }}
                </div>

                <div class="qcd-actions"><button type="submit" class="btn btn-primary">Enregistrer les réglages</button></div>
            {{ form_end(cacheForm) }}
        </section>

        {# ---------------- Vider le cache ---------------- #}
        <section class="qcd-panel" data-qcd-panel="purge">
            <div class="qcd-panel-head">
                <h3>Vider le cache</h3>
                <p>Supprimez les données mises en cache pour forcer leur régénération.</p>
            </div>

            <div class="qcd-callout qcd-callout-info">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                <span>Vider le cache est sans danger : les pages seront simplement recalculées à la prochaine visite. Utile après une grosse modification du catalogue ou du thème.</span>
            </div>

            <div class="qcd-section">
                <div class="qcd-section-title">Actions rapides</div>
                <div class="qcd-actions">
                    <button type="button" class="btn btn-danger" data-qcd-purge="all">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M8 6V4h8v2"></path><path d="M19 6l-1 14H6L5 6"></path></svg>
                        Tout vider
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-qcd-purge="expired">Compter les clés expirées</button>
                </div>
                <p class="qcd-hint">« Tout vider » supprime uniquement le cache de votre boutique (les autres boutiques ne sont pas touchées).</p>
            </div>

            <div class="qcd-section">
                <div class="qcd-section-title">Vidage ciblé (avancé)</div>
                <div class="qcd-field">
                    <label>Par préfixe</label>
                    <input type="text" id="qcd-purge-prefix" placeholder="ex. product_">
                    <button type="button" class="btn btn-outline-secondary" data-qcd-purge="prefix">Vider ce préfixe</button>
                </div>
                <div class="qcd-field">
                    <label>Par étiquettes (séparées par des virgules)</label>
                    <input type="text" id="qcd-purge-tags" placeholder="ex. category,cms">
                    <button type="button" class="btn btn-outline-secondary" data-qcd-purge="tags">Vider ces étiquettes</button>
                </div>
            </div>

            <p class="qcd-result" id="qcd-purge-result"></p>
        </section>

        {# ---------------- Préchauffage ---------------- #}
        <section class="qcd-panel" data-qcd-panel="warmup">
            <div class="qcd-panel-head">
                <h3>Préchauffage du cache</h3>
                <p>Visitez automatiquement vos pages pour remplir le cache à l'avance.</p>
            </div>

            <div class="qcd-callout qcd-callout-info">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                <span>Idéal après avoir vidé le cache : vos premiers visiteurs tomberont sur des pages déjà rapides. L'opération peut durer plusieurs minutes selon la taille du catalogue.</span>
            </div>

            <div class="qcd-section">
                <div class="qcd-section-title">1. Que faut-il préchauffer ?</div>
                <div class="qcd-choices">
                    <label class="qcd-choice"><input type="checkbox" class="qcd-warmup-type" value="home" checked> <span>Accueil</span></label>
                    <label class="qcd-choice"><input type="checkbox" class="qcd-warmup-type" value="categories" checked> <span>Catégories</span></label>
                    <label class="qcd-choice"><input type="checkbox" class="qcd-warmup-type" value="products" checked> <span>Produits</span></label>
                    <label class="qcd-choice"><input type="checkbox" class="qcd-warmup-type" value="cms" checked> <span>Pages CMS</span></label>
                </div>
                <div class="qcd-actions">
                    <button type="button" class="btn btn-primary" id="qcd-warmup-start">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                        Démarrer le préchauffage
                    </button>
                </div>
                <div class="qcd-progress"><div class="qcd-progress-bar" id="qcd-warmup-bar">0%</div></div>
                <p class="qcd-result" id="qcd-warmup-result"></p>
            </div>
        </section>

        {# ---------------- Statistiques ---------------- #}
        <section class="qcd-panel" data-qcd-panel="statistics">
            <div class="qcd-panel-head">
                <h3>Statistiques</h3>
                <p>Efficacité du cache et clés les plus volumineuses.</p>
            </div>
            <div class="qcd-actions">
                <button type="button" class="btn btn-outline-secondary" data-qcd-refresh="statistics">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path><path d="M3 21v-5h5"></path></svg>
                    Actualiser
                </button>
                <a class="btn btn-outline-secondary" id="qcd-export-csv" href="{{ path('qcdredis_admin_export_csv') }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Exporter en CSV
                </a>
            </div>
            <div id="qcd-stats-summary" class="qcd-grid"></div>
            <h4 class="qcd-subtitle">Clés les plus volumineuses</h4>
            <table class="table qcd-table" id="qcd-heavy-keys"><thead><tr><th>Clé</th><th>Taille (octets)</th><th>Expiration (s)</th></tr></thead><tbody></tbody></table>
        </section>

        {# ---------------- Diagnostic ---------------- #}
        <section class="qcd-panel" data-qcd-panel="diagnostic">
            <div class="qcd-panel-head">
                <h3>Diagnostic</h3>
                <p>Vérifiez que tout est correctement configuré, ou mesurez les performances.</p>
            </div>
            <div class="qcd-actions">
                <button type="button" class="btn btn-outline-secondary" data-qcd-refresh="diagnostic">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5Z"></path><path d="m9 12 2 2 4-4"></path></svg>
                    Lancer les vérifications
                </button>
                <button type="button" class="btn btn-outline-secondary" id="qcd-run-benchmark">Mesurer les performances</button>
            </div>
            <ul class="qcd-checks" id="qcd-diagnostic-list"></ul>
            <div id="qcd-benchmark-result" class="qcd-grid"></div>
        </section>

    </div>
</div>
<script src="{{ assetsUrl }}js/qcdredis.js"></script>
{% endblock %}
